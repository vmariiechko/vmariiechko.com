<footer class="mt-12 pt-6 border-t border-border text-sm text-muted">
  {% if site.newsletter.enabled %}
  <div class="footer-newsletter">
    {% include "partials/newsletter.njk" %}
  </div>
  {% endif %}
  <div class="grid grid-cols-2 gap-6 sm:grid-cols-3 justify-items-center">
    <div>
      <h3 class="font-bold">Topics</h3>
      <ul class="mt-2 space-y-1">
        <li><a href="/topics/databricks/" class="nav-link">Databricks</a></li>
        <li><a href="/topics/dlthub/" class="nav-link">dltHub</a></li>
        <li><a href="/topics/architecture/" class="nav-link">Architecture</a></li>
      </ul>
    </div>
    <div>
      <h3 class="font-bold">Feeds</h3>
      <ul class="mt-2 space-y-1">
        <li><a href="/feed.xml" class="nav-link">Writing (RSS)</a></li>
        <li><a href="/short-bytes.xml" class="nav-link">Short Bytes (RSS)</a></li>
      </ul>
    </div>
    <div>
      <h3 class="font-bold">Connect</h3>
      <ul class="mt-2 space-y-1">
        <li>
          <a href="https://github.com/vmariiechko" class="social-link" target="_blank" rel="noopener noreferrer">
            <span class="social-icon" aria-hidden="true">{% phicon "github-logo", "regular" %}</span>
            <span class="social-text">GitHub</span>
          </a>
        </li>
        <li>
          <a href="https://www.linkedin.com/in/mariiechko/" class="social-link" target="_blank" rel="noopener noreferrer">
            <span class="social-icon" aria-hidden="true">{% phicon "linkedin-logo", "regular" %}</span>
            <span class="social-text">LinkedIn</span>
          </a>
        </li>
        <li>
          <a href="mailto:{{ site.author.email }}" class="social-link" data-user="vmariiechko" data-domain="gmail.com">
            <span class="social-icon" aria-hidden="true">{% phicon "envelope", "regular" %}</span>
            <span class="social-text">Email</span>
          </a>
        </li>
      </ul>
    </div>
  </div>
  <div class="mt-8 text-center">
    <p>&copy; {% year %} {{ site.author.name }}. All rights reserved.</p>
  </div>
  <script>
    document.querySelectorAll('a[data-user][data-domain]').forEach(function(el) {
      el.href = 'mailto:' + el.dataset.user + '@' + el.dataset.domain;
    });
  </script>
</footer>
