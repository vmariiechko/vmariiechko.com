<header class="py-6">
  <div class="container mx-auto px-4 flex justify-between items-center">
    <a href="/" class="site-logo-link">
      <img src="/favicons/logo-dark.svg" alt="" class="site-logo site-logo-dark" width="53" height="55" aria-hidden="true">
      <img src="/favicons/logo-light.svg" alt="" class="site-logo site-logo-light" width="53" height="55" aria-hidden="true">
      <span class="hidden sm:inline text-2xl font-bold">{{ site.title }}</span>
    </a>

    <div class="header-actions flex items-center gap-4">
      <button type="button" id="search-toggle" class="theme-button" aria-label="Search">
        <span class="search">{% phicon "magnifying-glass", "regular" %}</span>
      </button>

      <button type="button" id="theme-toggle" class="theme-button" aria-label="Toggle theme" aria-pressed="false">
        <span class="sun">{% phicon "sun", "regular" %}</span>
        <span class="moon" style="display: none;">{% phicon "moon", "regular" %}</span>
      </button>

      {% if NODE_ENV === 'development' %}
        {# DEVELOPMENT: Show full theme picker for testing #}
        <details class="theme-picker">
          <summary class="theme-button" aria-label="Theme">
            {% phicon "paint-brush-broad", "regular" %}
          </summary>
          <div class="theme-menu" role="menu" aria-label="Choose theme">
            {% set choices = ["light","dark","light-blue","dark-blue"] %}
            {% for name in choices %}
              {% set theme = themes[name] %}
              <button
                type="button"
                role="menuitemradio"
                aria-checked="false"
                class="theme-chip"
                data-theme-choice="{{ name }}"
                style="--c1: {{ theme.swatch[0] }}; --c2: {{ theme.swatch[1] }}; --c3: {{ theme.swatch[2] }};"
                onclick="setTheme('{{ name }}'); this.closest('details').open=false;">
                <span class="sr-only">{{ name | capitalize }}</span>
                <span aria-hidden="true" class="chip-dots"></span>
              </button>
            {% endfor %}
          </div>
        </details>
      {% endif %}

      <button type="button" id="nav-toggle" class="theme-button md:hidden"
              aria-label="Open menu" aria-expanded="false" aria-controls="nav-menu">
        <span class="nav-icon-open">{% phicon "list", "regular" %}</span>
        <span class="nav-icon-close" style="display: none;">{% phicon "x", "regular" %}</span>
      </button>
    </div>

    <nav id="nav-menu" class="nav-menu" aria-label="Main navigation">
      <div class="nav-menu-backdrop"></div>
      <div class="nav-menu-card">
        <a href="/writing/" class="nav-link nav-menu-link">Writing</a>
        <a href="/short-bytes/" class="nav-link nav-menu-link">Short Bytes</a>
        <a href="/tags/" class="nav-link nav-menu-link">Tags</a>
        <a href="/about/" class="nav-link nav-menu-link">About</a>
      </div>
    </nav>
  </div>
</header>
