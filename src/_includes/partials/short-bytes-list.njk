{%- set items = pagination.items -%}
<ul class="space-y-4">
{%- for shortByte in items -%}
  {%- set allTags = [] -%}
  {%- if shortByte.data.tags -%}
    {%- for tag in shortByte.data.tags -%}
      {%- if tag != "Short Byte" -%}{%- set allTags = allTags | concat([tag]) -%}{%- endif -%}
    {%- endfor -%}
  {%- endif -%}
  <li class="pb-4" data-tags='{{ allTags | dump | safe }}'>
    <h2 class="text-2xl font-bold mb-2">
      <a href="{{ shortByte.url }}" class="nav-link">{{ shortByte.data.title }}</a>
    </h2>
    <div class="flex items-center justify-between flex-wrap gap-x-4 gap-y-2 mb-2">
      <div class="flex items-center gap-3 text-sm text-muted">
        <span class="flex items-center gap-1.5">
          <span aria-hidden="true">{% phicon "calendar", "regular", size=16 %}</span>
          <time datetime="{{ shortByte.date | htmlDateString }}">{{ shortByte.date | readableDate }}</time>
        </span>
        <span class="flex items-center gap-1.5">
          <span aria-hidden="true">{% phicon "clock", "regular", size=16 %}</span>
          <span>{{ shortByte | readingTime }}</span>
        </span>
      </div>
      {%- if shortByte.data.tags -%}
      <div class="flex items-center gap-2 flex-wrap">
        {%- set tagCount = 0 -%}
        {%- for tag in shortByte.data.tags -%}
          {%- if tag != "Short Byte" and tagCount < 3 -%}
            <a href="/tags/{{ tag | slugify }}/" class="tag-chip-sm hover:border-accent transition-colors">{{ tag }}</a>
            {%- set tagCount = tagCount + 1 -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
      {%- endif -%}
    </div>
    {%- if shortByte.data.description -%}
    <p class="text-muted">{{ shortByte.data.description }}</p>
    {%- endif -%}
  </li>
{%- endfor -%}
</ul>
