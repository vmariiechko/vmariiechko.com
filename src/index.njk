---
layout: layouts/base.njk
title: Home
---

{# Hero Section #}
<section class="hero mb-12">
  <div class="hero-avatar" aria-hidden="true">
    <img class="hero-avatar-dark" src="/assets/images/vadim-notion-avatar-dark.png" alt="" loading="eager" decoding="async">
    <img class="hero-avatar-light" src="/assets/images/vadim-notion-avatar-light.png" alt="" loading="eager" decoding="async">
  </div>
  <div class="hero-text">
    <h1>Hey 👋 I'm Vadym</h1>
    <p class="text-xl text-muted mb-4">
      Data Engineer exploring how to work smarter with data and sharing what actually works.
    </p>
    <a href="/about/" class="nav-link text-muted italic">More on About</a>
  </div>
</section>

{# Featured Section #}
<section class="mb-12">
  <h2>Featured</h2>
  <ul class="space-y-4">
    {%- for postUrl in featured.posts -%}
      {%- for post in collections.allContent -%}
        {%- if post.url == postUrl -%}
        <li class="flex items-start gap-3">
          <div class="flex-1">
            <div class="flex items-baseline gap-2">
              <a href="{{ post.url }}" class="nav-link text-2xl font-bold">{{ post.data.title }}</a>
              <span class="text-lg text-muted flex-shrink-0">{{ post | readingTime }}</span>
            </div>
            {%- if post.data.description -%}
            <p class="text-lg text-muted mt-1">{{ post.data.description }}</p>
            {%- endif -%}
          </div>
        </li>
        {%- endif -%}
      {%- endfor -%}
    {%- endfor -%}
  </ul>
</section>

{# Latest Section #}
<section class="mb-12">
  <h2>Latest</h2>
  <ul class="space-y-5">
    {%- for item in collections.allContent | limit(6) -%}
      {%- if item.url not in featured.posts -%}
      <li class="pb-5">
        <div class="flex items-start gap-3">
          <span class="text-muted flex-shrink-0 mt-1" aria-hidden="true" title="{{ 'Short Byte' if item.data.contentType == 'short-byte' else 'Post' }}">
            {%- if item.data.contentType == 'short-byte' -%}
              {% phicon "lightning", "regular", size=20 %}
            {%- else -%}
              {% phicon "notebook", "regular", size=20 %}
            {%- endif -%}
          </span>
          <div class="flex-grow min-w-0">
            <div class="flex items-baseline gap-2 flex-wrap">
              <a href="{{ item.url }}" class="nav-link text-2xl font-bold">{{ item.data.title }}</a>
              <span class="flex items-center gap-1.5 text-sm text-muted flex-shrink-0">
                <span aria-hidden="true">{% phicon "calendar", "regular", size=16 %}</span>
                <time datetime="{{ item.date | htmlDateString }}">{{ item.date | formatDate("LLL d") }}</time>
              </span>
              <span class="flex items-center gap-1.5 text-sm text-muted flex-shrink-0">
                <span aria-hidden="true">{% phicon "clock", "regular", size=16 %}</span>
                <span>{{ item | readingTime }}</span>
              </span>
            </div>
          </div>
        </div>
      </li>
      {%- endif -%}
    {%- endfor -%}
  </ul>

  <div class="flex items-center gap-6 mt-4 text-sm">
    <a href="/writing/" class="nav-link text-muted">See all writing</a>
    <a href="/short-bytes/" class="nav-link text-muted">See all short bytes</a>
  </div>
</section>

